# PostgreSQL
DATABASE_URL=postgres://ontime:ontime@localhost:5432/ontime?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Apple Sign In (required in production; set MOCK_AUTH=true for dev)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_FILE=./secrets/AuthKey.p8
APNS_BUNDLE_ID=com.example.ontime

# Google Maps Routes API (required in production; omit for mock)
GOOGLE_MAPS_API_KEY=

# Server
PORT=8080
ENVIRONMENT=development

# Mock flags (auto-enabled when ENVIRONMENT != production)
MOCK_MAPS=true
MOCK_APNS=true
MOCK_AUTH=true
